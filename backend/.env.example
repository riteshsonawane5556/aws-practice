
AWS_ACCESS_KEY_ID=your_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here

# The AWS region where your S3 bucket lives (e.g. us-east-1, ap-south-1).
AWS_REGION=us-east-1

# ── S3 Bucket ─────────────────────────────────────────────────────────────────
# The bucket must already exist. Create it in AWS Console > S3 > Create Bucket.
# Keep "Block all public access" ENABLED — presigned URLs handle access instead.
S3_BUCKET_NAME=your-bucket-name-here

# How long (seconds) presigned URLs remain valid before expiring.
# Default: 3600 (1 hour). Range: 1 – 604800 (7 days).
PRESIGNED_URL_EXPIRY=3600

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite file path relative to the project root.
# The file is created automatically when you run: uv run alembic upgrade head
DATABASE_URL=sqlite:///./images.db
